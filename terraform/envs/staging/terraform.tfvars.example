# AWS EKS — staging. All values have sane defaults; override only what you need.
# Auth comes from your AWS CLI environment (`aws configure` / env vars / SSO), not from here.
region             = "us-east-1"
cluster_version    = "1.30"
vpc_cidr           = "10.10.0.0/16"
node_instance_type = "t4g.large" # t4g.xlarge (16 GB) if the LGTM stack OOMs
node_ami_type      = "AL2023_ARM_64_STANDARD"

# Grant the CI GitHub-OIDC role cluster-admin (so deploy.yml can kubectl apply). Optional.
# admin_principal_arns = ["arn:aws:iam::123456789012:role/telos-infra-ci"]
